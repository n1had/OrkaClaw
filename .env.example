# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CRM ───────────────────────────────────────────────────────────────────────
HUBSPOT_PRIVATE_APP_TOKEN=pat-eu1-...

# ── Microsoft / Azure AD ──────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=<azure-app-client-id>
MICROSOFT_CLIENT_SECRET=<azure-app-client-secret>
MICROSOFT_TENANT_ID=<azure-tenant-id>

# ── Auth URLs ─────────────────────────────────────────────────────────────────
# Must match the Redirect URI registered in Azure AD app registration.
# Dev:        http://localhost:8000/auth/callback
# Production: https://<your-app>.azurecontainerapps.io/auth/callback
REDIRECT_URI=http://localhost:8000/auth/callback

# Root URL of the frontend — used for post-auth redirects.
# Dev:        http://localhost:5173   (Vite dev server)
# Production: https://<your-app>.azurecontainerapps.io  (same origin as backend)
FRONTEND_URL=http://localhost:5173

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Dev:        http://localhost:5173
# Production: https://<your-app>.azurecontainerapps.io
CORS_ORIGINS=http://localhost:5173

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ── App ───────────────────────────────────────────────────────────────────────
# Random secret used to sign JWT session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# ── Database ──────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=sqlite:///./orka.db
#
# Azure SQL (production):
# Install pyodbc: pip install pyodbc
# DATABASE_URL=mssql+pyodbc://<user>:<password>@<server>.database.windows.net/<db>?driver=ODBC+Driver+18+for+SQL+Server
